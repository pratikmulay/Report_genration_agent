<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Analysis Report — {{ branding.company_name or "GEMRSLIZE" }}</title>
    <link rel="stylesheet" href="report.css">
    <style>
        :root {
            --primary-color: {{ branding.primary_color or "#1A56DB" }};
        }
    </style>
</head>
<body>
    <!-- Header -->
    <header class="report-header">
        {% if branding.logo_base64 %}
        <div class="logo-container">
            <img src="data:image/png;base64,{{ branding.logo_base64 }}" alt="Logo" class="logo">
        </div>
        {% endif %}
        <div class="header-text">
            <h1 class="report-title">Analysis Report</h1>
            {% if branding.company_name %}
            <p class="company-name">{{ branding.company_name }}</p>
            {% endif %}
            {% if user_query %}
            <p class="user-query"><em>Query: {{ user_query }}</em></p>
            {% endif %}
            <p class="report-meta">Style: {{ report_style | title }} &bull; Generated by GEMRSLIZE</p>
        </div>
    </header>

    <hr class="divider">

    <!-- Table of Contents -->
    <nav class="toc">
        <h2>Contents</h2>
        <ul>
            {% if narratives.executive_summary %}<li><a href="#executive-summary">Executive Summary</a></li>{% endif %}
            {% if narratives.data_overview %}<li><a href="#data-overview">Data Overview</a></li>{% endif %}
            {% if narratives.sql_findings %}<li><a href="#sql-findings">SQL Analysis Findings</a></li>{% endif %}
            {% if narratives.ml_insights %}<li><a href="#ml-insights">Machine Learning Insights</a></li>{% endif %}
            {% if narratives.nlp_section %}<li><a href="#nlp-section">NLP &amp; Text Analysis</a></li>{% endif %}
            {% if include_charts %}<li><a href="#visualizations">Visualizations</a></li>{% endif %}
        </ul>
    </nav>

    <!-- Sections -->
    {% if narratives.executive_summary %}
    {% include "sections/executive_summary.html.j2" %}
    {% endif %}

    {% if narratives.data_overview %}
    {% include "sections/data_overview.html.j2" %}
    {% endif %}

    {% if narratives.sql_findings %}
    {% include "sections/sql_findings.html.j2" %}
    {% endif %}

    {% if narratives.ml_insights %}
    {% include "sections/ml_insights.html.j2" %}
    {% endif %}

    {% if narratives.nlp_section %}
    {% include "sections/nlp_section.html.j2" %}
    {% endif %}

    {% if include_charts %}
    {% include "sections/charts.html.j2" %}
    {% endif %}

    <!-- Footer -->
    <footer class="report-footer">
        <p>Generated by <strong>GEMRSLIZE Report Synthesis Agent</strong></p>
        <p class="disclaimer">This report was generated using AI-assisted analysis. Verify critical findings independently.</p>
    </footer>
</body>
</html>
